# Pakistan Terror Attacks Chatbot — Environment Configuration
# Copy this file to .env and fill in your values

# Grok API Key from xAI (https://console.x.ai)
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-4-1-fast-reasoning

# Server settings (backend API — NOT the public website port)
# Docker serves the website on port 8095; nginx proxies /api → backend:8000
HOST=0.0.0.0
PORT=8000

# CORS - set to your frontend URL in production
CORS_ORIGINS=*

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
